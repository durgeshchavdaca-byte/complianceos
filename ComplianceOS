generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String?
  password   String
  createdAt  DateTime @default(now())
  memberships OrganizationMember[]
}

model Organization {
  id         String   @id @default(uuid())
  name       String
  tenantSlug String   @unique
  createdAt  DateTime @default(now())
  members    OrganizationMember[]
  entities   Entity[]
}

model OrganizationMember {
  id        String @id @default(uuid())
  org       Organization @relation(fields: [orgId], references: [id])
  orgId     String
  user      User @relation(fields: [userId], references: [id])
  userId    String
  role      String
  createdAt DateTime @default(now())
}

model Entity {
  id               String   @id @default(uuid())
  org              Organization @relation(fields: [orgId], references: [id])
  orgId            String
  name             String
  entityType       String
  pan              String?
  incorporationDate DateTime?
  businessProfile  BusinessProfile?
  createdAt        DateTime @default(now())
}

model BusinessProfile {
  id               String @id @default(uuid())
  entity           Entity @relation(fields: [entityId], references: [id])
  entityId         String @unique
  turnover         Float?
  employeeCount    Int?
  gstRegistered    Boolean @default(false)
  importExport     Boolean @default(false)
  foreignOwnership Boolean @default(false)
  sectors          Json
  flags            Json
  createdAt        DateTime @default(now())
}

model Questionnaire {
  id        String @id @default(uuid())
  slug      String @unique
  title     String
  version   Int
  createdAt DateTime @default(now())
}

model UserAnswer {
  id             String @id @default(uuid())
  orgId          String
  entityId       String
  questionnaireId String
  questionKey    String
  answer         Json
  answeredBy     String
  answeredAt     DateTime @default(now())
}

model ComplianceItem {
  id                 String @id @default(uuid())
  code               String @unique
  title              String
  shortLabel         String
  category           String
  jurisdictionLevel  String
  triggerType        String
  triggerLogic       Json
  mandatoryStatus    String
  riskLevel          Int
  legalBasisSummary  String
  primaryAuthority   String
  primaryPortal      String
  formsOrFilings     Json
  recurring          Boolean @default(false)
  dueDateLogic       Json
  evidenceRequired   Json
  consequenceSummary String
  correctiveAction   String
  expertReviewFlag   Boolean @default(false)
  sourceLinks        Json
  sourceVersionDate  DateTime?
  createdAt          DateTime @default(now())
  rules              ComplianceRule[]
}

model ComplianceRule {
  id               String @id @default(uuid())
  complianceItem   ComplianceItem @relation(fields: [complianceItemId], references: [id])
  complianceItemId String
  ruleJson         Json
  priority         Int
  effectiveDate    DateTime
  expiresAt        DateTime?
  createdAt        DateTime @default(now())
}

model Assessment {
  id        String @id @default(uuid())
  orgId     String
  entityId  String
  runBy     String
  runAt     DateTime @default(now())
  confidence Float
  summary   Json
  items     AssessmentItem[]
}

model AssessmentItem {
  id               String @id @default(uuid())
  assessment       Assessment @relation(fields: [assessmentId], references: [id])
  assessmentId     String
  complianceItemId String
  status           String
  whyApplicable    String
  evidence         Json
  lastUpdated      DateTime @default(now())
}

model SourceDocument {
  id            String @id @default(uuid())
  title         String
  jurisdiction  String
  publishedDate DateTime?
  contentPath   String
  vectorId      String?
  createdAt     DateTime @default(now())
}

model ExpertReviewRequest {
  id               String @id @default(uuid())
  assessmentItem   AssessmentItem @relation(fields: [assessmentItemId], references: [id])
  assessmentItemId String
  requestedBy      String
  status           String
  notes            String?
  assignedTo       String?
  createdAt        DateTime @default(now())
}

model Subscription {
  id           String @id @default(uuid())
  org          Organization @relation(fields: [orgId], references: [id])
  orgId        String
  planId       String
  status       String
  startedAt    DateTime
  nextBillingAt DateTime?
}

model AuditLog {
  id        String @id @default(uuid())
  actorId   String?
  orgId     String?
  action    String
  meta      Json
  createdAt DateTime @default(now())
}
// prisma/seed.js
const { PrismaClient } = require('@prisma/client');
const prisma = new PrismaClient();

async function main() {
  const org = await prisma.organization.create({
    data: { name: 'Pilot Startup', tenantSlug: 'pilot-startup' }
  });

  const user = await prisma.user.create({
    data: { email: 'founder@example.com', name: 'Founder', password: 'HASHED_PASSWORD' }
  });

  await prisma.organizationMember.create({
    data: { orgId: org.id, userId: user.id, role: 'org_owner' }
  });

  const entity = await prisma.entity.create({
    data: { orgId: org.id, name: 'Pilot Pvt Ltd', entityType: 'PvtLtd' }
  });

  await prisma.businessProfile.create({
    data: {
      entityId: entity.id,
      turnover: 12000000,
      employeeCount: 8,
      gstRegistered: false,
      sectors: ['saas'],
      flags: {}
    }
  });

  await prisma.complianceItem.createMany({
    data: [
      {
        code: 'GST-REG',
        title: 'GST Registration',
        shortLabel: 'GST Reg',
        category: 'tax',
        jurisdictionLevel: 'central',
        triggerType: 'threshold',
        triggerLogic: JSON.stringify({ turnover_greater_than: 2000000 }),
        mandatoryStatus: 'mandatory_after_threshold',
        riskLevel: 8,
        legalBasisSummary: 'CGST Act',
        primaryAuthority: 'CBIC',
        primaryPortal: 'https://www.gst.gov.in',
        sourceLinks: JSON.stringify([{ id: 'src-gst', url: 'https://www.gst.gov.in' }])
      },
      {
        code: 'ESI-REG',
        title: 'ESI Registration',
        shortLabel: 'ESI',
        category: 'labour',
        jurisdictionLevel: 'central',
        triggerType: 'threshold',
        triggerLogic: JSON.stringify({ employee_count_greater_than: 10 }),
        mandatoryStatus: 'mandatory_after_threshold',
        riskLevel: 6,
        legalBasisSummary: 'ESI Act',
        primaryAuthority: 'ESIC',
        primaryPortal: 'https://www.esic.in',
        sourceLinks: JSON.stringify([{ id: 'src-esi', url: 'https://www.esic.in' }])
      }
    ]
  });

  console.log('Seed complete');
}

main()
  .catch(e => {
    console.error(e);
    process.exit(1);
  })
  .finally(async () => {
    await prisma.$disconnect();
  });
